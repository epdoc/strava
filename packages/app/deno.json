{
  "name": "@epdoc/strava-app",
  "version": "2.2.0",
  "description": "Strava athlete",
  "exports": {
    ".": "./src/mod.ts"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 100
  },
  "tasks": {
    "fmt": "deno fmt src test *.ts *.json",
    "lint": "deno lint src test",
    "check": "deno check *.ts *.json src test",
    "test": "deno test -A test",
    "run": "deno run -A ./main.ts",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs",
    "install": "deno install --global -A -f --name athlete-tool main.ts"
  },
  "license": "MIT",
  "imports": {
    "@epdoc/strava-api": "../api/src/mod.ts",
    "@epdoc/strava-app": "../app/src/mod.ts",
    "@epdoc/strava-core": "../core/src/mod.ts",
    "@epdoc/strava-schema": "../schema/src/mod.ts",
    "@epdoc/cliapp": "jsr:@epdoc/cliapp@^2.2.71",
    "@epdoc/daterange": "jsr:@epdoc/daterange@^3.0.6",
    "@epdoc/datetime": "jsr:@epdoc/datetime@^4.1.4",
    "@epdoc/duration": "jsr:@epdoc/duration@^0.3.16",
    "@epdoc/fs": "jsr:@epdoc/fs@^1.5.6",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.17",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.19/bdd",
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@opensrc/deno-open": "jsr:@opensrc/deno-open@^1.0.0"
  }
}
