{
  "name": "@epdoc/strava",
  "description": "A command line application to generate KML files suitable for import into Google Earth",
  "version": "2.2.3",
  "author": {
    "name": "James Pravetz",
    "email": "jpravetz@epdoc.com"
  },
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "bin": {
      "strava": "./main.ts"
    }
  },
  "compile": {
    "include": [
      "./src",
      "./build/build-info.json"
    ],
    "permissions": {
      "read": true,
      "write": true,
      "env": {
        "allow": true
      },
      "sys": true,
      "net": true
    }
  },
  "tasks": {
    "fmt": "deno fmt src test *.ts *.json",
    "lint": "deno lint",
    "check": "deno check src test main.ts",
    "test": "deno test -A",
    "run": "deno run -A ./main.ts",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs",
    "compile": "deno compile -P --output ${OUTPUT} ${INPUT}",
    "install": "mv ${OUTPUT} /Users/jpravetz/bin",
    "release": "deno task compile && deno task install",
    "install:debian": "deno cache --lock=deno.lock ./main.ts && /root/.deno/bin/deno install -f --global --config deno.json --name strava --lock=deno.lock --allow-net --allow-env --allow-sys --allow-read=/root/ --allow-write=/root/ ./main.ts",
    "install:mac": "deno cache --lock=deno.lock ./main.ts && deno install -f --global -A --config deno.json --name strava --lock=deno.lock ./main.ts"
  },
  "tests": {
    "include": [
      "test",
      "src/**/*.test.ts"
    ]
  },
  "imports": {
    "@epdoc/datetime": "jsr:@epdoc/datetime@^4.1.10",
    "@epdoc/strava-app": "../app/src/mod.ts",
    "@epdoc/strava-athlete": "../athlete/src/mod.ts",
    "@epdoc/strava-core": "../core/src/mod.ts",
    "@epdoc/strava-info": "../info/src/mod.ts",
    "@epdoc/strava-schema": "../schema/src/mod.ts",
    "@epdoc/cliapp": "jsr:@epdoc/cliapp@^2.2.80",
    "@epdoc/daterange": "jsr:@epdoc/daterange@^3.0.12",
    "@epdoc/fs": "jsr:@epdoc/fs@^1.5.15",
    "@epdoc/type": "jsr:@epdoc/type@^2.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/fmt/colors": "jsr:@std/fmt@^1.0.10/colors",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.19/bdd",
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@opensrc/deno-open": "jsr:@opensrc/deno-open@^1.0.0"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 100,
    "include": [
      "src",
      "test",
      "main.ts",
      "*.json"
    ],
    "exclude": [
      "test/readonly",
      "test/tmp"
    ]
  },
  "lint": {
    "include": [
      "src",
      "test",
      "main.ts",
      "*.json"
    ],
    "exclude": [
      "test/tmp",
      "test/readonly"
    ]
  }
}
