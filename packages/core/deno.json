{
  "name": "@epdoc/strava-core",
  "version": "2.2.1",
  "exports": "./src/mod.ts",
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check src test deno.json",
    "test": "deno test -A",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/cliapp": "jsr:@epdoc/cliapp@^2.2.76",
    "@epdoc/daterange": "jsr:@epdoc/daterange@^3.0.11",
    "@epdoc/datetime": "jsr:@epdoc/datetime@^4.1.10",
    "@epdoc/fs": "jsr:@epdoc/fs@^1.5.11",
    "@epdoc/logger": "jsr:@epdoc/logger@^1003.3.53",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.19/bdd"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 110,
    "include": [
      "deno.json",
      "src",
      "test"
    ],
    "exclude": [
      "test/readonly"
    ]
  },
  "lint": {
    "include": [
      "deno.json",
      "src",
      "test"
    ],
    "exclude": [
      "test/readonly"
    ]
  }
}
