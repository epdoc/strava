{
  "name": "@epdoc/strava",
  "description": "A command line application to generate KML files suitable for import into Google Earth",
  "version": "2.0.11",
  "author": {
    "name": "James Pravetz",
    "email": "jpravetz@epdoc.com"
  },
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "bin": {
      "strava": "./main.ts"
    }
  },
  "tasks": {
    "fmt": "deno fmt src test *.ts *.json",
    "lint": "deno lint",
    "check": "deno check src test main.ts",
    "test": "deno test -A",
    "run": "deno run -A ./main.ts",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs",
    "install": "deno eval \"const os = Deno.build.os; const task = os === 'darwin' ? 'install:mac' : 'install:debian'; console.log('Detected OS:', os); console.log('Running:', task); const cmd = new Deno.Command('deno', { args: ['task', task], stdout: 'inherit', stderr: 'inherit' }); await cmd.output();\"",
    "ginstall": "dtask install",
    "install:debian": "deno cache --lock=deno.lock ./main.ts && /root/.deno/bin/deno install -f --global --config deno.json --name strava --lock=deno.lock --allow-net --allow-env --allow-sys --allow-read=/root/ --allow-write=/root/ ./main.ts",
    "install:mac": "deno cache --lock=deno.lock ./main.ts && deno install -f --global -A --config deno.json --name strava --lock=deno.lock ./main.ts"
  },
  "tests": {
    "include": [
      "test",
      "src/**/*.test.ts"
    ]
  },
  "imports": {
    "@epdoc/strava-core": "../core/src/mod.ts",
    "@epdoc/strava-api": "../api/src/mod.ts",
    "@epdoc/strava-gpx": "../gpx/src/mod.ts",
    "@epdoc/strava-athlete": "../athlete/src/mod.ts",
    "@epdoc/cliapp": "jsr:@epdoc/cliapp@^2.2.7",
    "@epdoc/daterange": "jsr:@epdoc/daterange@^2.1.15",
    "@epdoc/datetime": "jsr:@epdoc/datetime@^3.2.11",
    "@epdoc/duration": "jsr:@epdoc/duration@^0.3.12",
    "@epdoc/fs": "jsr:@epdoc/fs@^1.3.8",
    "@epdoc/logger": "jsr:@epdoc/logger@^1003.3.18",
    "@epdoc/msgbuilder": "jsr:@epdoc/msgbuilder@^0.1.24",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.13",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.10",
    "@std/http": "jsr:@std/http@^1.1.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "commander": "npm:commander@^14.0.3",
    "xmlbuilder": "npm:xmlbuilder@^15.1.1",
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@opensrc/deno-open": "jsr:@opensrc/deno-open@^1.0.0",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.18/bdd"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 100,
    "include": [
      "src",
      "test",
      "main.ts",
      "*.json"
    ],
    "exclude": [
      "test/readonly",
      "test/tmp"
    ]
  },
  "lint": {
    "include": [
      "src",
      "test",
      "main.ts",
      "*.json"
    ],
    "exclude": [
      "test/tmp",
      "test/readonly"
    ]
  }
}
