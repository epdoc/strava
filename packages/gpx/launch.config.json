{
  "launch": {
    "groups": {
      "test": {
        "name": "Tests",
        "console": "internalConsole",
        "includes": [
          "**/*.test.ts"
        ],
        "runtimeArgs": [
          "test",
          "-A",
          "--inspect-brk"
        ]
      },
      "run": {
        "name": "Runnable",
        "console": "internalConsole",
        "includes": [
          "**/*.run.ts"
        ],
        "runtimeArgs": [
          "run",
          "-A",
          "--inspect-brk"
        ]
      },
      "main": {
        "name": "main",
        "console": "internalConsole",
        "program": "main.ts",
        "runtimeArgs": [
          "run",
          "-A",
          "--inspect-brk"
        ],
        "scripts": [
          "",
          "--help",
          "-d 202604",
          "-d 20260418-",
          "-d 20260418- --region CR,ON",
          "-d 20260415-20260429 --laps --blackout --region CR,ON"
        ]
      }
    }
  }
}
