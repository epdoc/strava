{
  "name": "@epdoc/strava-schema",
  "description": "Zod schemas and TypeScript types for the Strava API",
  "version": "2.0.5",
  "author": {
    "name": "James Pravetz",
    "email": "jpravetz@epdoc.com"
  },
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check src/**/*.ts test/**/*.ts",
    "test": "deno test -A",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "tests": {
    "include": [
      "test/**/*.ts",
      "src/**/*.test.ts"
    ]
  },
  "imports": {
    "@epdoc/type": "jsr:@epdoc/type@^1.2.11",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.17/bdd",
    "@std/expect": "jsr:@std/expect@^1.0.18/expect",
    "zod": "https://deno.land/x/zod@v3.23.8/mod.ts"
  },
  "lint": {
    "include": [
      "src",
      "test"
    ],
    "exclude": [
      "test/tmp",
      "test/readonly"
    ]
  }
}
