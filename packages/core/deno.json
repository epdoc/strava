{
  "name": "@epdoc/strava-core",
  "version": "2.0.15",
  "exports": "./src/mod.ts",
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check src test deno.json",
    "test": "deno test -A",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/cliapp": "jsr:@epdoc/cliapp@^2.2.7",
    "@epdoc/daterange": "jsr:@epdoc/daterange@^2.1.14",
    "@epdoc/fs": "jsr:@epdoc/fs@^1.3.8",
    "@epdoc/logger": "jsr:@epdoc/logger@^1003.3.18",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.13",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@epdoc/strava-schema": "../schema/src/mod.ts",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.18/bdd"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 110,
    "include": [
      "deno.json",
      "src",
      "test"
    ],
    "exclude": [
      "test/readonly"
    ]
  },
  "lint": {
    "include": [
      "deno.json",
      "src",
      "test"
    ],
    "exclude": [
      "test/readonly"
    ]
  }
}
