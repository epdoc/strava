{
  "name": "@epdoc/strava-athlete",
  "version": "2.1.1",
  "description": "Strava athlete",
  "exports": {
    ".": "./src/mod.ts"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 100
  },
  "tasks": {
    "fmt": "deno fmt src test *.ts *.json",
    "lint": "deno lint src test",
    "check": "deno check *.ts *.json src test",
    "test": "deno test -A test",
    "run": "deno run -A ./main.ts",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs",
    "install": "deno install --global -A -f --name athlete-tool main.ts"
  },
  "license": "MIT",
  "imports": {
    "@epdoc/cliapp": "jsr:@epdoc/cliapp@^2.1.22",
    "@epdoc/daterange": "jsr:@epdoc/daterange@^2.1.7",
    "@epdoc/datetime": "jsr:@epdoc/datetime@^3.2.6",
    "@epdoc/duration": "jsr:@epdoc/duration@^0.3.10",
    "@epdoc/fs": "jsr:@epdoc/fs@^1.3.5",
    "@epdoc/logger": "jsr:@epdoc/logger@^1003.3.12",
    "@epdoc/msgbuilder": "jsr:@epdoc/msgbuilder@^0.1.20",
    "@epdoc/terminal": "jsr:@epdoc/terminal@^0.0.12",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.11",
    "@epdoc/strava-app": "../strava-app/src/mod.ts",
    "@epdoc/strava-core": "../core/src/mod.ts",
    "@epdoc/strava-api": "../strava-api/src/mod.ts",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "xmlbuilder": "npm:xmlbuilder@^15.1.1"
  }
}
