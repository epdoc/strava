{
  "name": "@epdoc/strava-schema",
  "description": "TypeScript types and type guards for the Strava API",
  "version": "2.0.10",
  "author": {
    "name": "James Pravetz",
    "email": "jpravetz@epdoc.com"
  },
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts",
    "./activity": "./src/activity.ts",
    "./athlete": "./src/athlete.ts",
    "./consts": "./src/consts.ts",
    "./gear": "./src/gear.ts",
    "./segment": "./src/segment.ts",
    "./stream": "./src/stream.ts",
    "./types": "./src/types.ts",
    "./types/units": "./src/types/units.ts",
    "./zones": "./src/zones.ts"
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check src/**/*.ts",
    "test": "deno test -A",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "tests": {
    "include": [
      "test/**/*.ts",
      "src/**/*.test.ts"
    ],
    "exclude": [
      "test-zod"
    ]
  },
  "imports": {
    "@epdoc/type": "jsr:@epdoc/type@^1.2.13",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.18/bdd",
    "@std/expect": "jsr:@std/expect@^1.0.19/expect"
  },
  "lint": {
    "include": [
      "src"
    ],
    "exclude": [
      "test/tmp",
      "test/readonly",
      "src-zod",
      "test-zod"
    ]
  }
}
