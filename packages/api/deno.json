{
  "name": "@epdoc/strava-api",
  "description": "Strava API",
  "version": "2.0.14",
  "author": {
    "name": "James Pravetz",
    "email": "jpravetz@epdoc.com"
  },
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts"
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check src/**/*.ts test/**/*.ts",
    "test": "deno test -A",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "tests": {
    "include": [
      "test/**/*.ts",
      "src/**/*.test.ts"
    ]
  },
  "imports": {
    "@epdoc/strava-schema": "../schema/src/mod.ts",
    "@epdoc/cliapp": "jsr:@epdoc/cliapp@^2.2.14",
    "@epdoc/daterange": "jsr:@epdoc/daterange@^2.1.15",
    "@epdoc/strava-core": "../core/src/mod.ts",
    "@epdoc/datetime": "jsr:@epdoc/datetime@^3.2.11",
    "@epdoc/duration": "jsr:@epdoc/duration@^0.3.12",
    "@epdoc/fs": "jsr:@epdoc/fs@^1.3.9",
    "@epdoc/logger": "jsr:@epdoc/logger@^1003.3.20",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.13",
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@opensrc/deno-open": "jsr:@opensrc/deno-open@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.18/bdd",
    "@std/expect": "jsr:@std/expect@^1.0.19/expect"
  },
  "lint": {
    "include": [
      "src",
      "test"
    ],
    "exclude": [
      "test/tmp",
      "test/readonly"
    ]
  }
}
