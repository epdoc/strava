{
  "name": "@epdoc/strava-core",
  "version": "2.0.11",
  "exports": "./src/mod.ts",
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check src test deno.json",
    "test": "deno test -A",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/cliapp": "jsr:@epdoc/cliapp@^2.1.22",
    "@epdoc/daterange": "jsr:@epdoc/daterange@^2.1.7",
    "@epdoc/datetime": "jsr:@epdoc/datetime@^3.2.6",
    "@epdoc/fs": "jsr:@epdoc/fs@^1.3.5",
    "@epdoc/logger": "jsr:@epdoc/logger@^1003.3.12",
    "@epdoc/terminal": "jsr:@epdoc/terminal@^0.0.12",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.11",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/testing": "jsr:@std/testing@^1.0.17"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 110,
    "include": [
      "deno.json",
      "src",
      "test"
    ],
    "exclude": [
      "test/readonly"
    ]
  },
  "lint": {
    "include": [
      "deno.json",
      "src",
      "test"
    ],
    "exclude": [
      "test/readonly"
    ]
  }
}
